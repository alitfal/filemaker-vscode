{
    "comments": {
        "lineComment": "//",
        "blockComment": [ "/*", "*/" ]
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    "autoClosingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"", "\""],
        ["'", "'"]
    ],
    "surroundingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"", "\""],
        ["'", "'"]
    ],
    "indentationRules": {
        "increaseIndentPattern": "^\\s*(If|Else|Else If|Loop|Case|Let|While)\\b.*",
        "decreaseIndentPattern": "^\\s*(End If|End Loop|Else|Else If)\\b.*"
    },
    "onEnterRules": [
        {
            "beforeText": "^\\s*(If|Else|Else If|Loop|While)\\b.*",
            "action": { "indent": "indent" }
        },
        {
            "beforeText": "^\\s*(End If|End Loop)\\b.*",
            "action": { "indent": "outdent" }
        }
    ]
}
