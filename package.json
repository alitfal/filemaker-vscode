{
  "name": "filemaker-vscode-updated",
  "displayName": "FileMaker VSCode (Updated)",
  "description": "FileMaker syntax highlighting, snippets, and functions \u2014 updated through FileMaker 2025 (v22)",
  "version": "2.0.2",
  "publisher": "alitfal",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/alitfal/filemaker-vscode"
  },
  "icon": "resources/filemaker-vscode-128.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onCommand:functions.jsonToJsonSetElement"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "functions.jsonToJsonSetElement",
        "title": "FileMaker: JSON to JSONSetElement()"
      }
    ],
    "languages": [
      {
        "id": "filemaker",
        "aliases": [
          "FileMaker",
          "Filemaker",
          "filemaker"
        ],
        "extensions": [
          ".fmfn",
          ".calc",
          ".fmcalc",
          ".fmscript"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "filemaker",
        "scopeName": "source.filemaker",
        "path": "./syntaxes/FileMaker.tmLanguage"
      }
    ],
    "snippets": [
      {
        "language": "filemaker",
        "path": "./snippets/filemaker.json"
      }
    ]
  },
  "dependencies": {
    "fm-json-to-jsonsetelement": "file:./fm-json-lib"
  },
  "devDependencies": {
    "@types/glob": "^7.2.0",
    "@types/mocha": "^9.1.1",
    "@types/node": "20.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^5.30.0",
    "@typescript-eslint/parser": "^5.30.0",
    "@vscode/test-electron": "^2.1.5",
    "eslint": "^8.18.0",
    "glob": "^8.0.3",
    "mocha": "^10.0.0",
    "typescript": "^5.4.0"
  },
  "__metadata": {
    "id": "4fcfaefb-c1c8-49ea-8ef1-27ae57a23ed6",
    "publisherDisplayName": "Joshua Willing",
    "publisherId": "bfe42675-c248-494a-b8c5-af81b25e9c64",
    "isPreReleaseVersion": false
  },
  "keywords": [
    "filemaker",
    "claris",
    "fmfn",
    "calc",
    "snippets",
    "syntax"
  ],
  "bugs": {
    "url": "https://github.com/alitfal/filemaker-vscode/issues"
  },
  "homepage": "https://github.com/alitfal/filemaker-vscode"
}