{
  "name": "filemaker-vscode-updated",
  "displayName": "FileMaker Dev Tools",
  "description": "FileMaker / Claris Pro syntax highlighting, snippets and autocompletion. Full FM 2026 coverage: 225+ functions, 200+ script steps, 136 Get() params, AI/embeddings/RAG support.",
  "version": "2.4.3",
  "publisher": "alitfal",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/alitfal/filemaker-vscode"
  },
  "icon": "resources/filemaker-vscode-128.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:filemaker"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "functions.jsonToJsonSetElement",
        "title": "FileMaker: JSON to JSONSetElement()"
      },
      {
        "command": "filemaker.connect",
        "title": "FileMaker: Connect to Server"
      },
      {
        "command": "filemaker.switchConnection",
        "title": "FileMaker: Switch Connection"
      },
      {
        "command": "filemaker.refreshSchema",
        "title": "FileMaker: Refresh Schema"
      },
      {
        "command": "filemaker.disconnect",
        "title": "FileMaker: Disconnect"
      },
      {
        "command": "filemaker.showStatus",
        "title": "FileMaker: Show Connection Status"
      }
    ],
    "languages": [
      {
        "id": "filemaker",
        "aliases": [
          "FileMaker",
          "Filemaker",
          "filemaker"
        ],
        "extensions": [
          ".fmfn",
          ".calc",
          ".fmcalc",
          ".fmscript"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "filemaker",
        "scopeName": "source.filemaker",
        "path": "./syntaxes/FileMaker.tmLanguage"
      }
    ],
    "snippets": [
      {
        "language": "filemaker",
        "path": "./snippets/filemaker.json"
      }
    ],
    "themes": [
      {
        "label": "FileMaker Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/filemaker-dark.json"
      }
    ],
    "configuration": {
      "title": "FileMaker Dev Tools",
      "properties": {
        "filemaker.connections": {
          "type": "array",
          "default": [],
          "description": "FileMaker Server connections",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Connection profile name"
              },
              "server": {
                "type": "string",
                "description": "FileMaker Server URL"
              },
              "database": {
                "type": "string",
                "description": "Database name"
              }
            }
          }
        },
        "filemaker.activeConnection": {
          "type": "string",
          "default": "",
          "description": "Active connection profile name"
        },
        "filemaker.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Auto-refresh schema when connecting"
        }
      }
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@types/glob": "^7.2.0",
    "@types/mocha": "^9.1.1",
    "@types/node": "20.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^5.30.0",
    "@typescript-eslint/parser": "^5.30.0",
    "@vscode/test-electron": "^2.1.5",
    "eslint": "^8.18.0",
    "glob": "^8.0.3",
    "mocha": "^10.0.0",
    "typescript": "^5.4.0"
  },
  "__metadata": {
    "id": "4fcfaefb-c1c8-49ea-8ef1-27ae57a23ed6",
    "publisherDisplayName": "Joshua Willing",
    "publisherId": "bfe42675-c248-494a-b8c5-af81b25e9c64",
    "isPreReleaseVersion": false
  },
  "keywords": [
    "filemaker",
    "claris",
    "fmfn",
    "calc",
    "snippets",
    "syntax"
  ],
  "bugs": {
    "url": "https://github.com/alitfal/filemaker-vscode/issues"
  },
  "homepage": "https://github.com/alitfal/filemaker-vscode"
}